{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Termax",
  "version": "0.1.2",
  "identifier": "com.termax.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Termax",
        "width": 1100,
        "height": 720,
        "minWidth": 640,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "visible": false,
        "backgroundColor": "#121314"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://api.github.com/repos/termax/termax/releases/latest"],
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "startMenuFolder": "Termax",
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
